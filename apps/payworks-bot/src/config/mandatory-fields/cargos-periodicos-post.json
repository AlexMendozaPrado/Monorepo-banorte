{
  "_meta": {
    "note": "F4 — Cargos Periódicos Post manual v2.1 (19-Jun-2025). Transactions: VTA (AUTH), DEV (REFUND), CAN (VOID), REV (REVERSAL). NO soporta PRE/POS/VERIFY/AMEX. Cambios vs versión anterior: MERCHANT_ID maxLen 7, TERMINAL_ID maxLen 10 (específico de este producto) y ahora R, USER/MODE con maxLen, AMOUNT regex 18 dígitos, REFERENCE numérico 12, ENTRY_MODE solo [MANUAL], MARKETPLACE_TX con PROHIBITED para MC, nuevo ID_GATEWAY con PROHIBITED para VISA. ID_MAC como variable de retorno. AN5822: ver layer-an5822.json (valores correctos para este producto: PAYMENT_IND=R, COF=4 en MIT).",
    "pendingRule": "PROHIBITED: requiere soporte en FieldRequirement.ts"
  },
  "integrationType": "CARGOS_PERIODICOS_POST",
  "manualVersion": "2.1",
  "manualDate": "2025-06-19",
  "displayName": "Cargos Periódicos Post",
  "servlet": {
    "MERCHANT_ID": {
      "manualName": "ID_AFILIACION",
      "displayName": "ID Afiliación",
      "dataType": "numeric",
      "ambiguous": false,
      "rules": {
        "AUTH_VISA": "R", "AUTH_MC": "R",
        "REFUND_VISA": "R", "REFUND_MC": "R",
        "VOID_VISA": "R", "VOID_MC": "R",
        "REVERSAL_VISA": "R", "REVERSAL_MC": "R"
      },
      "maxLength": 7,
      "format": "^\\d{1,7}$"
    },
    "USER": {
      "manualName": "USUARIO",
      "displayName": "Usuario",
      "dataType": "alphanum",
      "ambiguous": false,
      "rules": {
        "AUTH_VISA": "R", "AUTH_MC": "R",
        "REFUND_VISA": "R", "REFUND_MC": "R",
        "VOID_VISA": "R", "VOID_MC": "R",
        "REVERSAL_VISA": "R", "REVERSAL_MC": "R"
      },
      "maxLength": 20
    },
    "PASSWORD": {
      "manualName": "CLAVE_USR",
      "displayName": "Clave de Usuario",
      "dataType": "alphanum",
      "ambiguous": true,
      "note": "PCI-DSS: nunca en logs. Validado en envío del comercio, no contra log.",
      "rules": {
        "AUTH_VISA": "N/A", "AUTH_MC": "N/A",
        "REFUND_VISA": "N/A", "REFUND_MC": "N/A",
        "VOID_VISA": "N/A", "VOID_MC": "N/A",
        "REVERSAL_VISA": "N/A", "REVERSAL_MC": "N/A"
      },
      "maxLength": 20
    },
    "TERMINAL_ID": {
      "manualName": "ID_TERMINAL",
      "displayName": "ID Terminal",
      "dataType": "alphanum",
      "ambiguous": false,
      "note": "FIX: Manual v2.1 dice 'Alfanumérico 10, Sí para cualquier transacción'. En otros productos es 15; en Cargos Periódicos Post es 10. Antes estaba como O/15.",
      "rules": {
        "AUTH_VISA": "R", "AUTH_MC": "R",
        "REFUND_VISA": "R", "REFUND_MC": "R",
        "VOID_VISA": "R", "VOID_MC": "R",
        "REVERSAL_VISA": "R", "REVERSAL_MC": "R"
      },
      "maxLength": 10
    },
    "CMD_TRANS": {
      "manualName": "CMD_TRANS",
      "displayName": "Comando Transacción",
      "dataType": "enum",
      "ambiguous": false,
      "note": "Valores: VENTA|AUTH | DEVOLUCION|REFUND | CANCELACION|VOID | REVERSA|REVERSAL. No PREAUT/POSTAUT/VERIFY.",
      "rules": {
        "AUTH_VISA": "R", "AUTH_MC": "R",
        "REFUND_VISA": "R", "REFUND_MC": "R",
        "VOID_VISA": "R", "VOID_MC": "R",
        "REVERSAL_VISA": "R", "REVERSAL_MC": "R"
      },
      "maxLength": 20
    },
    "MODE": {
      "manualName": "MODO",
      "displayName": "Modo",
      "dataType": "enum",
      "ambiguous": false,
      "note": "Alfanumérico 3. Valores: PRD|AUT|DEC|RND",
      "rules": {
        "AUTH_VISA": "R", "AUTH_MC": "R",
        "REFUND_VISA": "R", "REFUND_MC": "R",
        "VOID_VISA": "R", "VOID_MC": "R",
        "REVERSAL_VISA": "R", "REVERSAL_MC": "R"
      },
      "validValues": ["PRD", "AUT", "DEC", "RND"],
      "maxLength": 3
    },
    "AMOUNT": {
      "manualName": "MONTO",
      "displayName": "Monto",
      "dataType": "decimal",
      "ambiguous": false,
      "note": "Manual: Numérico 18 dígitos y 2 decimales. maxLength 21 = 18 dígitos + '.' + 2 decimales.",
      "rules": {
        "AUTH_VISA": "R", "AUTH_MC": "R",
        "REFUND_VISA": "O", "REFUND_MC": "O",
        "VOID_VISA": "N/A", "VOID_MC": "N/A",
        "REVERSAL_VISA": "N/A", "REVERSAL_MC": "N/A"
      },
      "format": "^\\d{1,18}(\\.\\d{1,2})?$",
      "maxLength": 21
    },
    "REFERENCE": {
      "manualName": "REFERENCIA",
      "displayName": "Referencia",
      "dataType": "numeric",
      "ambiguous": false,
      "note": "Manual: Numérico 12. Cambió de alfanumérico 15 en versión previa.",
      "rules": {
        "AUTH_VISA": "O", "AUTH_MC": "O",
        "REFUND_VISA": "R", "REFUND_MC": "R",
        "VOID_VISA": "R", "VOID_MC": "R",
        "REVERSAL_VISA": "R", "REVERSAL_MC": "R"
      },
      "format": "^\\d{1,12}$",
      "maxLength": 12
    },
    "CONTROL_NUMBER": {
      "manualName": "NUMERO_CONTROL",
      "displayName": "Número de Control",
      "dataType": "alphanum",
      "ambiguous": false,
      "note": "Manual v2.1: Requerida para cualquier transacción o comando. Combinación MERCHANT_ID + CONTROL_NUMBER debe ser única (regla cruzada C7).",
      "rules": {
        "AUTH_VISA": "R", "AUTH_MC": "R",
        "REFUND_VISA": "R", "REFUND_MC": "R",
        "VOID_VISA": "R", "VOID_MC": "R",
        "REVERSAL_VISA": "R", "REVERSAL_MC": "R"
      },
      "maxLength": 30
    },
    "CARD_NUMBER": {
      "manualName": "NUMERO_TARJETA",
      "displayName": "Número de Tarjeta",
      "dataType": "masked",
      "ambiguous": false,
      "rules": {
        "AUTH_VISA": "R", "AUTH_MC": "R",
        "REFUND_VISA": "N/A", "REFUND_MC": "N/A",
        "VOID_VISA": "N/A", "VOID_MC": "N/A",
        "REVERSAL_VISA": "N/A", "REVERSAL_MC": "N/A"
      },
      "maxLength": 20,
      "mustBeMasked": true
    },
    "EXP_DATE": {
      "manualName": "FECHA_EXP",
      "displayName": "Fecha de Expiración",
      "dataType": "MMYY",
      "ambiguous": false,
      "note": "PCI-DSS: no aparece en logs. Manual dice R para VENTA. Relajado a O por no verificabilidad.",
      "rules": {
        "AUTH_VISA": "O", "AUTH_MC": "O",
        "REFUND_VISA": "N/A", "REFUND_MC": "N/A",
        "VOID_VISA": "N/A", "VOID_MC": "N/A",
        "REVERSAL_VISA": "N/A", "REVERSAL_MC": "N/A"
      },
      "format": "^(0[1-9]|1[0-2])[0-9]{2}$",
      "maxLength": 4
    },
    "SECURITY_CODE": {
      "manualName": "CODIGO_SEGURIDAD",
      "displayName": "Código de Seguridad (CVV/CVC)",
      "dataType": "numeric",
      "ambiguous": false,
      "note": "PCI-DSS: nunca en logs.",
      "rules": {
        "AUTH_VISA": "N/A", "AUTH_MC": "N/A",
        "REFUND_VISA": "N/A", "REFUND_MC": "N/A",
        "VOID_VISA": "N/A", "VOID_MC": "N/A",
        "REVERSAL_VISA": "N/A", "REVERSAL_MC": "N/A"
      },
      "format": "^\\d{3,4}$",
      "maxLength": 4
    },
    "ENTRY_MODE": {
      "manualName": "MODO_ENTRADA",
