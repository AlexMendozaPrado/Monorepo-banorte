      "rules": {
        "AUTH_VISA": "R", "AUTH_MC": "R",
        "REFUND_VISA": "N/A", "REFUND_MC": "N/A",
        "VOID_VISA": "N/A", "VOID_MC": "N/A",
        "REVERSAL_VISA": "N/A", "REVERSAL_MC": "N/A"
      },
      "validValues": ["MANUAL"]
    },
    "BATCH": {
      "manualName": "LOTE",
      "displayName": "Lote",
