{
  "_meta": {
    "note": "Cargos Periódicos Post manual v2.1 (19-Jun-2025). Alineado al PDF oficial. Transacciones: VENTA (AUTH), DEVOLUCION (REFUND), CANCELACION (VOID), REVERSA (REVERSAL), VERIFICACION (VERIFY). NO soporta PREAUT/POSTAUT/AMEX. AN5822 mapping en layer-an5822.json: PAYMENT_IND=R (Recurrente), COF=4 en subseqMIT. GROUP (LOTE) Opcional (p.8).",
    "specSource": "Manual Cargos Periódicos Post v2.1 (19-Jun-2025). Revisado contra PDF oficial el 2026-04-22. Fixes: SECURITY_CODE removido (el manual v2.1 p.6-7 NO lo lista — Cargos Periódicos no pide CVV porque es MIT recurrente); BATCH → GROUP rename; ID_GATEWAY removido (Gateway 7118 MC pertenece a Agregadores v2.6.4); PASSWORD → R_PCI; EXP_DATE → R_PCI VENTA; ENTRY_MODE maxLen 20."
  },
  "integrationType": "CARGOS_PERIODICOS_POST",
  "manualVersion": "2.1",
  "manualDate": "2025-06-19",
  "displayName": "Cargos Periódicos Post",
  "servlet": {
    "MERCHANT_ID": {
      "manualName": "ID_AFILIACION",
      "displayName": "ID Afiliación",
      "dataType": "numeric",
      "ambiguous": false,
      "rules": {
        "AUTH_VISA": "R", "AUTH_MC": "R",
        "REFUND_VISA": "R", "REFUND_MC": "R",
        "VOID_VISA": "R", "VOID_MC": "R",
        "REVERSAL_VISA": "R", "REVERSAL_MC": "R"
      },
      "maxLength": 7,
      "format": "^\\d{1,7}$"
    },
    "USER": {
      "manualName": "USUARIO",
      "displayName": "Usuario",
      "dataType": "alphanum",
      "ambiguous": false,
      "rules": {
        "AUTH_VISA": "R", "AUTH_MC": "R",
        "REFUND_VISA": "R", "REFUND_MC": "R",
        "VOID_VISA": "R", "VOID_MC": "R",
        "REVERSAL_VISA": "R", "REVERSAL_MC": "R"
      },
      "maxLength": 20
    },
    "PASSWORD": {
      "manualName": "CLAVE_USR",
      "displayName": "Clave de Usuario",
      "dataType": "alphanum",
      "ambiguous": false,
      "note": "Manual v2.1 p.6: R para cualquier transacción o comando. PCI-DSS: no aparece en logs, por eso R_PCI.",
      "rules": {
        "AUTH_VISA": "R_PCI", "AUTH_MC": "R_PCI",
        "REFUND_VISA": "R_PCI", "REFUND_MC": "R_PCI",
        "VOID_VISA": "R_PCI", "VOID_MC": "R_PCI",
        "REVERSAL_VISA": "R_PCI", "REVERSAL_MC": "R_PCI"
      },
      "maxLength": 20
    },
    "TERMINAL_ID": {
      "manualName": "ID_TERMINAL",
      "displayName": "ID Terminal",
      "dataType": "alphanum",
      "ambiguous": false,
      "note": "FIX: Manual v2.1 dice 'Alfanumérico 10, Sí para cualquier transacción'. En otros productos es 15; en Cargos Periódicos Post es 10. Antes estaba como O/15.",
      "rules": {
        "AUTH_VISA": "R", "AUTH_MC": "R",
        "REFUND_VISA": "R", "REFUND_MC": "R",
        "VOID_VISA": "R", "VOID_MC": "R",
        "REVERSAL_VISA": "R", "REVERSAL_MC": "R"
      },
      "maxLength": 10
    },
    "CMD_TRANS": {
      "manualName": "CMD_TRANS",
      "displayName": "Comando Transacción",
      "dataType": "enum",
      "ambiguous": false,
      "note": "Valores: VENTA|AUTH | DEVOLUCION|REFUND | CANCELACION|VOID | REVERSA|REVERSAL. No PREAUT/POSTAUT/VERIFY.",
      "rules": {
        "AUTH_VISA": "R", "AUTH_MC": "R",
        "REFUND_VISA": "R", "REFUND_MC": "R",
        "VOID_VISA": "R", "VOID_MC": "R",
        "REVERSAL_VISA": "R", "REVERSAL_MC": "R"
      },
      "maxLength": 20
    },
    "MODE": {
      "manualName": "MODO",
      "displayName": "Modo",
      "dataType": "enum",
      "ambiguous": false,
      "note": "Alfanumérico 3. Valores: PRD|AUT|DEC|RND",
      "rules": {
        "AUTH_VISA": "R", "AUTH_MC": "R",
        "REFUND_VISA": "R", "REFUND_MC": "R",
        "VOID_VISA": "R", "VOID_MC": "R",
        "REVERSAL_VISA": "R", "REVERSAL_MC": "R"
      },
      "validValues": ["PRD", "AUT", "DEC", "RND"],
      "maxLength": 3
    },
    "AMOUNT": {
      "manualName": "MONTO",
      "displayName": "Monto",
      "dataType": "decimal",
      "ambiguous": false,
      "note": "Manual: Numérico 18 dígitos y 2 decimales. maxLength 21 = 18 dígitos + '.' + 2 decimales.",
      "rules": {
        "AUTH_VISA": "R", "AUTH_MC": "R",
        "REFUND_VISA": "O", "REFUND_MC": "O",
        "VOID_VISA": "N/A", "VOID_MC": "N/A",
        "REVERSAL_VISA": "N/A", "REVERSAL_MC": "N/A"
      },
      "format": "^\\d{1,18}(\\.\\d{1,2})?$",
      "maxLength": 21
    },
    "REFERENCE": {
      "manualName": "REFERENCIA",
      "displayName": "Referencia",
      "dataType": "numeric",
      "ambiguous": false,
      "note": "Manual: Numérico 12. Cambió de alfanumérico 15 en versión previa.",
      "rules": {
        "AUTH_VISA": "O", "AUTH_MC": "O",
        "REFUND_VISA": "R", "REFUND_MC": "R",
        "VOID_VISA": "R", "VOID_MC": "R",
        "REVERSAL_VISA": "R", "REVERSAL_MC": "R"
      },
      "format": "^\\d{1,12}$",
      "maxLength": 12
    },
    "CONTROL_NUMBER": {
      "manualName": "NUMERO_CONTROL",
      "displayName": "Número de Control",
      "dataType": "alphanum",
      "ambiguous": false,
      "note": "Manual v2.1: Requerida para cualquier transacción o comando. Combinación MERCHANT_ID + CONTROL_NUMBER debe ser única (regla cruzada C7).",
      "rules": {
        "AUTH_VISA": "R", "AUTH_MC": "R",
        "REFUND_VISA": "R", "REFUND_MC": "R",
        "VOID_VISA": "R", "VOID_MC": "R",
        "REVERSAL_VISA": "R", "REVERSAL_MC": "R"
      },
      "maxLength": 30
    },
    "CARD_NUMBER": {
      "manualName": "NUMERO_TARJETA",
      "displayName": "Número de Tarjeta",
      "dataType": "masked",
      "ambiguous": false,
      "rules": {
        "AUTH_VISA": "R", "AUTH_MC": "R",
        "REFUND_VISA": "N/A", "REFUND_MC": "N/A",
        "VOID_VISA": "N/A", "VOID_MC": "N/A",
        "REVERSAL_VISA": "N/A", "REVERSAL_MC": "N/A"
      },
      "maxLength": 20,
      "mustBeMasked": true
    },
    "EXP_DATE": {
      "manualName": "FECHA_EXP",
      "displayName": "Fecha de Expiración",
      "dataType": "MMYY",
      "ambiguous": false,
      "note": "Manual v2.1 p.7: Numérico 4 (MMAA), R solo para VENTA. PCI-DSS: no aparece en logs, por eso R_PCI.",
      "rules": {
        "AUTH_VISA": "R_PCI", "AUTH_MC": "R_PCI",
        "REFUND_VISA": "N/A", "REFUND_MC": "N/A",
        "VOID_VISA": "N/A", "VOID_MC": "N/A",
        "REVERSAL_VISA": "N/A", "REVERSAL_MC": "N/A"
      },
      "format": "^(0[1-9]|1[0-2])[0-9]{2}$",
      "maxLength": 4
    },
    "ENTRY_MODE": {
      "manualName": "MODO_ENTRADA",
      "displayName": "Modo de Entrada",
      "dataType": "enum",
      "ambiguous": false,
      "note": "Manual v2.1 p.7: Alfanumérico 20. R solo para VENTA. Valor: MANUAL (tarjeta NO presente).",
      "rules": {
        "AUTH_VISA": "R", "AUTH_MC": "R",
        "REFUND_VISA": "N/A", "REFUND_MC": "N/A",
        "VOID_VISA": "N/A", "VOID_MC": "N/A",
        "REVERSAL_VISA": "N/A", "REVERSAL_MC": "N/A"
      },
      "validValues": ["MANUAL"],
      "maxLength": 20
    },
    "GROUP": {
      "manualName": "LOTE",
      "displayName": "Lote",
      "dataType": "alphanum",
      "ambiguous": false,
      "note": "Manual v2.1 p.8: Alfanumérico 30, Opcional. Identificador asignado por el cliente para agrupar transacciones. (Antes BATCH — logName oficial del manual es GROUP.)",
      "rules": {
        "AUTH_VISA": "O", "AUTH_MC": "O",
        "REFUND_VISA": "O", "REFUND_MC": "O",
        "VOID_VISA": "O", "VOID_MC": "O",
        "REVERSAL_VISA": "O", "REVERSAL_MC": "O"
      },
      "maxLength": 30
    },
    "RESPONSE_LANGUAGE": {
      "manualName": "IDIOMA_RESPUESTA",
      "displayName": "Idioma de Respuesta",
      "dataType": "enum",
      "ambiguous": false,
      "note": "Manual v2.1 p.8: Alfanumérico 2, Opcional. Default ES. Valores: ES, EN.",
      "rules": {
        "AUTH_VISA": "O", "AUTH_MC": "O",
        "REFUND_VISA": "O", "REFUND_MC": "O",
        "VOID_VISA": "O", "VOID_MC": "O",
        "REVERSAL_VISA": "O", "REVERSAL_MC": "O"
      },
      "validValues": ["ES", "EN"],
      "maxLength": 2
    },
    "CUSTOMER_REF1": {
      "manualName": "REF_CLIENTE1",
      "displayName": "Referencia Cliente 1",
      "dataType": "alphanum",
      "ambiguous": false,
      "rules": {
        "AUTH_VISA": "O", "AUTH_MC": "O",
        "REFUND_VISA": "O", "REFUND_MC": "O",
        "VOID_VISA": "O", "VOID_MC": "O",
        "REVERSAL_VISA": "O", "REVERSAL_MC": "O"
      },
      "maxLength": 30
    },
    "CUSTOMER_REF2": {
      "manualName": "REF_CLIENTE2",
      "displayName": "Referencia Cliente 2",
      "dataType": "alphanum",
      "ambiguous": false,
      "note": "FIX: maxLength era 30, manual dice 16.",
      "rules": {
        "AUTH_VISA": "O", "AUTH_MC": "O",
        "REFUND_VISA": "O", "REFUND_MC": "O",
        "VOID_VISA": "O", "VOID_MC": "O",
        "REVERSAL_VISA": "O", "REVERSAL_MC": "O"
      },
      "maxLength": 16
    },
    "CUSTOMER_REF3": {
      "manualName": "REF_CLIENTE3",
      "displayName": "Referencia Cliente 3 (identificador del suscriptor)",
      "dataType": "alphanum",
      "ambiguous": false,
      "note": "R en Cargos Periódicos Post: identifica al suscriptor. Manual: 'Número de contrato del Tarjetahabiente con el comercio'. Alfanumérico 20.",
      "rules": {
        "AUTH_VISA": "R", "AUTH_MC": "R",
        "REFUND_VISA": "R", "REFUND_MC": "R",
        "VOID_VISA": "R", "VOID_MC": "R",
        "REVERSAL_VISA": "R", "REVERSAL_MC": "R"
      },
      "maxLength": 20
    },
    "CUSTOMER_REF4": {
      "manualName": "REF_CLIENTE4",
      "displayName": "Referencia Cliente 4",
      "dataType": "alphanum",
      "ambiguous": false,
      "rules": {
        "AUTH_VISA": "O", "AUTH_MC": "O",
        "REFUND_VISA": "O", "REFUND_MC": "O",
        "VOID_VISA": "O", "VOID_MC": "O",
        "REVERSAL_VISA": "O", "REVERSAL_MC": "O"
      },
      "maxLength": 30
    },
    "CUSTOMER_REF5": {
      "manualName": "REF_CLIENTE5",
      "displayName": "Referencia Cliente 5",
      "dataType": "alphanum",
      "ambiguous": false,
      "rules": {
        "AUTH_VISA": "O", "AUTH_MC": "O",
        "REFUND_VISA": "O", "REFUND_MC": "O",
        "VOID_VISA": "O", "VOID_MC": "O",
        "REVERSAL_VISA": "O", "REVERSAL_MC": "O"
      },
      "maxLength": 30
    },
    "MARKETPLACE_TX": {
      "manualName": "MARKETPLACE_TX",
      "displayName": "Marketplace Transaction",
      "dataType": "numeric",
      "ambiguous": false,
      "note": "Manual v2.1 p.8: Numérico 1, valor fijo 1. Solo cuando se cumplen condiciones: compra fuera de México, VISA, VENTA. NO se debe mandar con MC.",
      "rules": {
        "AUTH_VISA": "O", "AUTH_MC": "PROHIBITED",
        "REFUND_VISA": "N/A", "REFUND_MC": "N/A",
        "VOID_VISA": "N/A", "VOID_MC": "N/A",
        "REVERSAL_VISA": "N/A", "REVERSAL_MC": "N/A"
      },
      "fixedValue": "1",
      "maxLength": 1
    }
  },
  "responseFields": {
    "_note": "Campos de retorno específicos de Cargos Periódicos Post v2.1",
    "ID_MAC": {
      "manualName": "ID_MAC",
      "displayName": "ID MAC (Mandato AN7110 MasterCard)",
      "dataType": "alphanum",
      "ambiguous": false,
      "note": "Variable de RETORNO del autorizador. Solo transacciones internacionales MC. U=Prepago, V=Virtual.",
      "rules": {
        "AUTH_VISA": "N/A", "AUTH_MC": "O"
      },
      "validValues": ["U", "V"],
      "maxLength": 1
    },
    "PAYW_RESULT_Z": {
      "_note": "RECORDATORIO: el dominio de PAYW_RESULT en response-rules.json debe incluir 'Z' (Reversa automática por timeout) que el manual v2.1 añade. Tu response-rules.json actual tiene solo [A, D, R, T]."
    }
  }
}
