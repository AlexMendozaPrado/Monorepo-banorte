      "validValues": ["U", "V"],
      "maxLength": 1
    },
    "PAYW_RESULT_Z": {
      "_note": "RECORDATORIO: el dominio de PAYW_RESULT en response-rules.json debe incluir 'Z' (Reversa automática por timeout) que el manual v2.1 añade. Tu response-rules.json actual tiene solo [A, D, R, T]."
    }
