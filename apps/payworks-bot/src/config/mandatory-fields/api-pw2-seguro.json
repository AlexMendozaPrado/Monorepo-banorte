  "emvVoucher": {
    "_description": "Campos EMV que el SDK (PPGetXXX) retorna al comercio DESPUÉS de procesar la transacción, con el único propósito de imprimir el voucher físico. NO son de envío a Banorte. Por eso no se validan contra el log del servlet. Se incluyen aquí con fines documentales y para validar logs de dispositivo PinPad si llegan a analizarse.",
    "_source": "Manual API PW2 Seguro v2.4, Anexo 'Generación de vouchers por parte del comercio' + Anexo V (Tabla de parámetros).",
    "TVR": {
      "manualName": "TVR",
