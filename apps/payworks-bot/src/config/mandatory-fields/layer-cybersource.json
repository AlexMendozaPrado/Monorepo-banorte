{
  "_meta": {
    "note": "F4 — Capa Cybersource Direct manual v1.10 (18-Ene-2021). URL: https://via.banorte.com/bancyb/procesadorHttp.htm. Aplica a ECOMMERCE_TRADICIONAL y VENTANA_COMERCIO_ELECTRONICO. Cambios vs anterior: Card_cardType validValues corregido [001, 002] (NO soporta AMEX=003), agregado MerchantID con fixedValue=banorteixe, BillTo_ipAddress añadido como R (cambió de O a R en v1.6 Jul-2023), agregadas variables de RETORNO (decision, requestID, reasonCode, Bnte_code, afsReply_afsResult), agregado BillTo_httpBrowserEmail y Comments opcionales.",
    "url": "https://via.banorte.com/bancyb/procesadorHttp.htm",
    "decisionFlow": {
      "ACCEPT": "Enviar a Payworks con ID_CYBERSOURCE = requestID",
      "REVIEW": "Enviar a 3D Secure; si autenticación exitosa, enviar a Payworks con ID_CYBERSOURCE, STATUS_3D, ECI, XID (si no vacío), CAVV",
      "REJECT": "Fin de operación. NO enviar a Payworks.",
      "ERROR": "Fin de operación. NO enviar a Payworks."
    },
    "notSupported": "NO soporta American Express. Card_cardType solo VISA (001) y MasterCard (002).",
    "deviceFingerprint": "Anexo 1 del manual describe el JavaScript que el comercio debe embeber en su página antes del botón de pago. DeviceFingerprintID debe ser un UUID/hash único por sesión. Dos ejemplos documentados: producción y pruebas."
  },
  "integrationType": "LAYER_CYBERSOURCE",
