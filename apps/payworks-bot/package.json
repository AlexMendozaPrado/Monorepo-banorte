{
  "name": "payworks-bot",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3006",
    "build": "next build",
    "start": "next start --port 3006",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf .next .turbo node_modules/.cache",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest --testPathPatterns=unit",
    "cypress": "cypress open",
    "cypress:headless": "cypress run",
    "test:e2e": "start-server-and-test dev http://localhost:3006 cypress:headless",
    "test:e2e:open": "start-server-and-test dev http://localhost:3006 cypress",
    "fixtures:generate": "tsx scripts/generate-fixtures.ts",
    "fixtures:validate": "tsx scripts/generate-fixtures.ts --validate"
  },
  "dependencies": {
    "@banorte/ui": "workspace:*",
    "docxtemplater": "^3.68.6",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.553.0",
    "next": "^14.2.0",
    "pizzip": "^3.2.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.4.0",
    "uuid": "^9.0.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@banorte/eslint-config": "workspace:*",
    "@banorte/typescript-config": "workspace:*",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.10.5",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "@types/uuid": "^9.0.7",
    "autoprefixer": "^10.4.0",
    "cypress": "^15.5.0",
    "cypress-file-upload": "^5.0.8",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "postcss": "^8.5.6",
    "start-server-and-test": "^2.1.2",
    "ts-jest": "^29.4.5",
    "tsx": "^4.19.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
